# ================================================
# APP CONFIG
# ================================================
PORT=8000
NODE_ENV=development

# URL public của server (quan trọng khi deploy — Swagger dùng URL này để gọi API đúng chỗ)
# Local:      SERVER_URL=http://localhost:8000
# Production: SERVER_URL=https://your-app.onrender.com
SERVER_URL=http://localhost:8000

# ================================================
# JWT CONFIG
# Tạo secret key: openssl rand -base64 32
# ================================================
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=15m

JWT_REFRESH_SECRET=your_refresh_secret_here_different_from_above
JWT_REFRESH_EXPIRES_IN=30d

# ================================================
# SUPABASE CONFIG
# Lấy tại: https://supabase.com/dashboard > Project Settings > API
# ================================================
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ================================================
# CLOUDINARY CONFIG
# Lấy tại: https://cloudinary.com/console
# ================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ================================================
# RESEND CONFIG
# Lấy tại: https://resend.com/api-keys
# ================================================
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev

# ================================================
# OAUTH CONFIG (chỉ điền provider bạn muốn dùng)
# ================================================

# --- Google ---
# Lấy tại: https://console.cloud.google.com > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/google/callback

# --- GitHub ---
# Lấy tại: https://github.com/settings/developers > OAuth Apps > New OAuth App
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:8000/api/auth/github/callback

# ================================================
# FRONTEND URL (dùng cho link trong email + OAuth redirect)
# ================================================
FRONTEND_URL=http://localhost:3001

# ================================================
# CORS — Danh sách domain được phép gọi API từ trình duyệt
# Nếu có nhiều domain thì cách nhau bằng dấu phẩy, KHÔNG có dấu cách
# Ví dụ: CORS_ORIGINS=https://myapp.com,https://admin.myapp.com
# ================================================
CORS_ORIGINS=http://localhost:3001,http://localhost:5173
